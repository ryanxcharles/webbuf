---
import { Code } from "astro:components";

interface Props {
  code: string;
  lang?: "ts" | "bash" | "js" | "json";
}

const { code, lang = "ts" } = Astro.props;
---

<div class="overflow-hidden rounded-lg border border-border">
  <Code code={code} lang={lang} theme="tokyo-night" />
</div>

<style is:global>
  /* The Shiki tokyo-night theme carries its own background; make the padding
     part of the code surface so it reads as one block. */
  .astro-code {
    margin: 0;
    padding: 1rem;
    font-size: 0.875rem;
    line-height: 1.6;
    overflow-x: auto;
  }
</style>

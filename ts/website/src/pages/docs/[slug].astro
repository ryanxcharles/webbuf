---
import type { GetStaticPaths } from "astro";
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
import { PACKAGES } from "../../data/packages";

export const getStaticPaths = (() =>
  PACKAGES.map((pkg, index) => ({
    params: { slug: pkg.slug },
    props: {
      pkg,
      prev: index > 0 ? PACKAGES[index - 1] : undefined,
      next: index < PACKAGES.length - 1 ? PACKAGES[index + 1] : undefined,
    },
  }))) satisfies GetStaticPaths;

const { pkg, prev, next } = Astro.props;
---

<DocsLayout
  title={`${pkg.npm} · WebBuf`}
  description={pkg.summary}
  active={pkg.slug}
>
  <p class="text-xs font-semibold tracking-wide text-muted uppercase">
    {pkg.category}
  </p>
  <h1 class="mt-1 font-mono text-2xl font-bold break-words sm:text-3xl">
    {pkg.npm}
  </h1>
  <p class="mt-3 text-lg text-muted">{pkg.summary}</p>
  <p class="mt-4">{pkg.description}</p>

  <h2 class="mt-8 text-sm font-semibold tracking-wide text-accent uppercase">
    Install
  </h2>
  <div class="mt-3">
    <CodeBlock code={pkg.install} lang="bash" />
  </div>

  {
    pkg.usage && (
      <>
        <h2 class="mt-8 text-sm font-semibold tracking-wide text-accent uppercase">
          Usage
        </h2>
        <div class="mt-3">
          <CodeBlock code={pkg.usage} lang="ts" />
        </div>
      </>
    )
  }

  <nav
    class="mt-12 flex justify-between border-t border-border pt-6 text-sm"
    aria-label="Pagination"
  >
    {
      prev ? (
        <a href={`/docs/${prev.slug}`} class="text-muted hover:text-accent">
          &larr; {prev.npm}
        </a>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <a
          href={`/docs/${next.slug}`}
          class="text-right text-muted hover:text-accent"
        >
          {next.npm} &rarr;
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</DocsLayout>

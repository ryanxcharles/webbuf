---
import Layout from "./Layout.astro";
import { CATEGORIES, packagesByCategory } from "../data/packages";

interface Props {
  title?: string;
  description?: string;
  /** Slug of the active package, to highlight in the sidebar. */
  active?: string;
}

const { title, description, active } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="flex flex-col gap-10 md:flex-row">
    <aside class="md:w-56 md:shrink-0">
      <nav class="md:sticky md:top-20" aria-label="Documentation">
        <a
          href="/docs"
          class:list={[
            "block text-sm font-semibold",
            active === undefined ? "text-accent" : "hover:text-accent",
          ]}
        >
          Overview
        </a>
        {
          CATEGORIES.map((category) => (
            <div class="mt-5">
              <p class="text-xs font-semibold tracking-wide text-muted uppercase">
                {category}
              </p>
              <ul class="mt-2 space-y-1">
                {packagesByCategory(category).map((pkg) => (
                  <li>
                    <a
                      href={`/docs/${pkg.slug}`}
                      class:list={[
                        "block text-sm",
                        pkg.slug === active
                          ? "font-medium text-accent"
                          : "text-muted hover:text-fg",
                      ]}
                    >
                      {pkg.npm}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </aside>
    <div class="min-w-0 flex-1">
      <slot />
    </div>
  </div>
</Layout>
